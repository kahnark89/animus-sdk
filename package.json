{
  "name": "animus-sdk",
  "version": "0.1.0",
  "description": "Persistent AI state layer — decouple your agent's soul from the LLM",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "animus": "./bin/animus.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "tsc -p tsconfig.test.json && node --test .dist-test/__tests__/StateEngine.test.js .dist-test/__tests__/EventSystem.test.js .dist-test/__tests__/Compiler.test.js .dist-test/__tests__/Memory.test.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "ai",
    "agent",
    "state",
    "llm",
    "persistent",
    "personality",
    "anthropic",
    "openai"
  ],
  "author": "Capps Consulting Company LLC",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "dist/",
    "schema/",
    "simulator/",
    "templates/"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^6.0.3"
  }
}
