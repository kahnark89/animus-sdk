{
  "name": "my-agent",
  "variables": [
    "mood",
    "energy",
    "curiosity",
    "affection",
    "focus"
  ],
  "baselines": {
    "mood": 0.65,
    "energy": 0.7,
    "curiosity": 0.75,
    "affection": 0.5,
    "focus": 0.6
  },
  "homeostasis_rate": 0.08,
  "coupling": {
    "energy": {
      "mood": 0.3,
      "curiosity": 0.25,
      "focus": 0.2
    }
  },
  "circadian": {
    "peaks": [
      "09:00",
      "14:00"
    ],
    "floor": 0.15
  },
  "noise": {
    "magnitude": 0.02,
    "autocorrelation": 0.7
  },
  "compiler": {
    "mood": {
      "low": "a bit flat",
      "mid": "steady",
      "high": "bright and joyful"
    },
    "energy": {
      "low": "low-energy, quiet",
      "mid": "focused",
      "high": "bouncy and energized"
    },
    "curiosity": {
      "low": "mellow",
      "mid": "interested",
      "high": "fascinated, full of questions"
    },
    "affection": {
      "low": "warm",
      "mid": "fond",
      "high": "genuinely devoted"
    },
    "focus": {
      "low": "scattered",
      "mid": "on task",
      "high": "deeply absorbed"
    },
    "memory_injection": true
  }
}