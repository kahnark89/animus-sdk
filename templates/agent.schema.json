{
  "name": "my-agent",
  "id": "my-agent",
  "variables": [
    "mood",
    "energy",
    "curiosity",
    "affection",
    "focus"
  ],
  "baselines": {
    "mood": 0.65,
    "energy": 0.7,
    "curiosity": 0.75,
    "affection": 0.5,
    "focus": 0.6
  },
  "homeostasis_rate": 0.08,
  "coupling": {
    "energy": {
      "mood": 0.3,
      "curiosity": 0.25,
      "focus": 0.2
    }
  },
  "circadian": {
    "peaks": [
      "09:00",
      "14:00"
    ],
    "floor": 0.15
  },
  "noise": {
    "magnitude": 0.02,
    "autocorrelation": 0.7
  },
  "event_sensitivity": {
    "delight": 1.0,
    "reunion": 1.0,
    "fatigue": 1.0,
    "confusion": 1.0,
    "absence": 1.0
  },
  "triggers": [
    { "condition": "elapsed_days > 1",  "fire": "absence", "cooldown_steps": 1440 },
    { "condition": "energy < 0.20",     "fire": "fatigue", "cooldown_steps": 60  }
  ],
  "growth": {
    "rules": [
      { "trigger": "delight_count > 50",  "shifts": { "mood": 0.02, "affection": 0.01 } },
      { "trigger": "reunion_count > 20",  "shifts": { "affection": 0.03 } },
      { "trigger": "fatigue_count > 30",  "shifts": { "energy": -0.02 } }
    ]
  },
  "compiler": {
    "mood": {
      "low": "a bit flat",
      "mid": "steady",
      "high": "bright and joyful"
    },
    "energy": {
      "low": "low-energy, quiet",
      "mid": "focused",
      "high": "bouncy and energized"
    },
    "curiosity": {
      "low": "mellow",
      "mid": "interested",
      "high": "fascinated, full of questions"
    },
    "affection": {
      "low": "warm",
      "mid": "fond",
      "high": "genuinely devoted"
    },
    "focus": {
      "low": "scattered",
      "mid": "on task",
      "high": "deeply absorbed"
    },
    "memory_injection": true
  }
}