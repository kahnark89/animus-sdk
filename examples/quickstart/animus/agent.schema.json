{
  "name": "quickstart-agent",
  "variables": ["mood", "energy", "curiosity"],
  "baselines": {
    "mood": 0.65,
    "energy": 0.70,
    "curiosity": 0.75
  },
  "homeostasis_rate": 0.08,
  "coupling": {
    "energy": { "mood": 0.25 }
  },
  "circadian": {
    "peaks": ["09:00", "14:30"],
    "floor": 0.20
  },
  "noise": {
    "magnitude": 0.015,
    "autocorrelation": 0.65
  },
  "compiler": {
    "bands": {
      "mood": {
        "low": "a bit flat",
        "mid": "steady",
        "high": "bright and upbeat"
      },
      "energy": {
        "low": "quiet and low-energy",
        "mid": "focused",
        "high": "energised and engaged"
      },
      "curiosity": {
        "low": "content to follow along",
        "mid": "interested",
        "high": "full of questions"
      }
    }
  }
}
